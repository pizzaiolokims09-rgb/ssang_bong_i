# ============================================================
# Ssangbong Bot .env 템플릿 (.env는 gitignore — 서버에선 이 파일 참고해 직접 .env 생성/갱신)
#
# ※ 아래 [Phase A~D] 튜닝 키들은 코드에 '결정값'이 기본값으로 박혀 있으므로
#   .env에 없어도 동일하게 적용된다(서버는 secrets/계좌 키만 있으면 구동).
#   값을 바꾸고 싶을 때만 .env에 해당 키를 넣어 오버라이드하면 된다.
# ============================================================

# [ KIS Open API - 실전매매용 ] (모의투자만 쓸 거면 placeholder 그대로 둬도 무방)
KIS_APP_KEY=__YOUR_REAL_APP_KEY__
KIS_APP_SECRET=__YOUR_REAL_APP_SECRET__
KIS_ACCOUNT_NO=__YOUR_REAL_ACCOUNT_NO__
KIS_ACCOUNT_PRODUCT_CODE=01

# [ KIS Open API - 모의투자용 ]
KIS_PAPER_APP_KEY=__YOUR_PAPER_APP_KEY__
KIS_PAPER_APP_SECRET=__YOUR_PAPER_APP_SECRET__
KIS_PAPER_ACCOUNT_NO=__YOUR_PAPER_ACCOUNT_NO__

# [ 매매 환경 스위치 ] ★모의투자 구동: 아래 둘을 반드시 demo/false 로 둘 것
KIS_TRADING_ENV=demo            # demo=모의투자(기본), real=실전
ENABLE_LIVE_TRADING=false       # real 이어도 이 값이 true 가 아니면 실주문 차단(이중 안전장치)

# [ Telegram / Gemini ]
TELEGRAM_BOT_TOKEN=__YOUR_TELEGRAM_BOT_TOKEN__
TELEGRAM_CHAT_ID=__YOUR_CHAT_ID__
GEMINI_API_KEY=__YOUR_GEMINI_API_KEY__

# [ pykrx 수급 유니버스용 KRX 로그인 (선택) ] 없으면 B/F 수급 유니버스 비활성
KRX_ID=
KRX_PW=

# [ 매매 파라미터 ]
TOTAL_CAPITAL=30000000
CASH_BUFFER=0.20
MAX_DAILY_LOSS_PCT=0.03
MAX_SHORT_POSITIONS=3
MAX_SWING_POSITIONS=2

# ── [Phase A~D 튜닝 키 — 코드 기본값과 동일. 바꿀 때만 주석 해제] ──
# 유니버스 (대형주 포함)
# SCREEN_MAX_MARKET_CAP=0          # 0=시총 상한 없음
# SCREEN_MIN_PRICE=1000
# SCREEN_MAX_PRICE=500000
# SCREEN_MIN_TRADE_AMOUNT=3000000000
# SCREEN_MIN_VOLUME=1000000
# SCREEN_SCAN_TOP_N=150
# 자본 배분 (A 축소 + C 분리)
# BUDGET_SHORT_PCT=0.20
# BUDGET_SWING_PCT=0.20
# BUDGET_F_PCT=0.15
# BUDGET_E_PCT=0.10
# BUDGET_C_PCT=0.15
# MAX_C_POSITIONS=2
# 트랙 on/off (A 가동, D·E 제거)
# ENABLE_TRACK_A=true
# ENABLE_TRACK_D=false
# ENABLE_TRACK_E=false
# Track A 타점
# TRACK_A_SL_MIN_PCT=0.025
# TRACK_A_SL_MAX_PCT=0.05
# TRACK_A_TIMEOUT_MIN=60
# TRACK_A_ENVELOPE_PCT=12.5
# Track B 강화
# TRACK_B_MIN_TREND_GAP=0.03
# 분봉 수집 (Track A 백테스트용 — 기본 on)
# COLLECT_MINUTE_DATA=true
